<component type="desktop-application">
  <id>nl.thatzokay.avio</id>
  <name>AVIO</name>
  <summary>AVIO - Linux In-Vehicle Infotainment</summary>
  <description>
    <p>
      AVIO is an open-source Apple CarPlay and Android Auto head unit for Linux.
      It supports hardware-accelerated video decoding, low-latency audio, multitouch
      and D-Pad navigation using CPC200-CCPA and CPC200-CCPW dongles.
    </p>
  </description>
