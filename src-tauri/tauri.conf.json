{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "avio",
  "version": "0.1.0-2",
  "identifier": "nl.thatzokay.avio",
  "build": {
    "beforeDevCommand": "bun scripts/build-gst-host-sidecar.ts && bun scripts/build-avio-compositor-sidecar.ts && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun scripts/build-gst-host-sidecar.ts && bun scripts/build-avio-compositor-sidecar.ts && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "avio",
        "decorations": false,
        "resizable": true,
        "fullscreen": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "enableGTKAppId": true,
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2NzUzMTRFNTIzOUVCRTkKUldUcDZ6bFNUakYxMW9VTXhYVHJuaVVmSGdqTGpWSm1Nb3lHZFREbHRBbUo3OU40eHJvZG5LbUcK",
      "endpoints": [
        "https://thatzokay.github.io/AVIO/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/gst-host"
    ],
    "resources": [
      "assets/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
